# ===== Esempio di variabili d'ambiente per Scacchi =====
# Copia questo file in ".env" e adatta i valori. NON committare il file ".env" reale.
# I nomi qui sotto sono indicativi: saranno consolidati con lo scaffold del codice.

# ----- Backend (FastAPI) -----
# In sviluppo è sufficiente SQLite; in produzione usare PostgreSQL.
DATABASE_URL=sqlite:///./scacchi.db
# Esempio PostgreSQL:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/scacchi
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Chiave per firmare i token/sessioni (genera un valore casuale robusto)
SECRET_KEY=cambia-questo-valore

# Token per l'interfaccia super admin (modifica dei parametri di programma).
# Senza questo valore la modifica dei parametri è disabilitata.
ADMIN_TOKEN=cambia-questo-token-admin

# ----- Giocatori IA (Qwen, Claude, OpenAI, …) -----
# I token dei provider IA si configurano dalla pagina super admin «Provider IA»
# (/admin/ia/) e sono salvati nel database: NON è più necessario toccare il .env.
# Se nessun provider attivo ha un token valido, l'IA usa un giocatore locale
# ottimale (minimax con potatura alpha-beta) come fallback.
#
# Le variabili Qwen qui sotto sono OPZIONALI e servono solo alla migrazione: al
# primo avvio, se presenti, popolano il provider "qwen" (poi gestito da UI).
QWEN_API_KEY=
# Endpoint: internazionale di default. Per la Cina:
# https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
# Timeout (secondi) per la chiamata all'IA remota; oltre, si usa il giocatore locale.
# AI_TIMEOUT vale per tutti i provider; QWEN_TIMEOUT resta come alias retro-compatibile.
AI_TIMEOUT=10

# ----- Frontend (Django) -----
DJANGO_SECRET_KEY=cambia-questo-valore
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# URL con cui il frontend Django raggiunge il backend FastAPI
BACKEND_API_URL=http://127.0.0.1:8000
